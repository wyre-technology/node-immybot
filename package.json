{
  "name": "@wyre-technology/node-immybot",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/npm": "^11.0.0",
    "@types/node": "^20.0.0",
    "msw": "^2.14.6",
    "semantic-release": "^23.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "description": "Node.js/TypeScript client library for the ImmyBot API",
  "keywords": [
    "typescript",
    "sdk",
    "api-client",
    "msp",
    "immybot",
    "kaseya"
  ],
  "author": "WYRE Technology",
  "license": "Apache-2.0"
}
